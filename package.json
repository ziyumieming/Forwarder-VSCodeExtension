{
  "name": "forwarder",
  "displayName": "Forwarder",
  "description": "Design of VSCode Intelligent Visual Analysis Plugin for Code Understanding",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "forwarder.analyze0",
        "title": "Go Forwarder"
      },
      {
        "command": "forwarder.analyze",
        "title": "Analyze: 分析当前文件代码结构"
      },
      {
        "command": "forwarder.debug.analyze",
        "title": "Debug: 检验流程通行性"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forwarder-sidebar",
          "title": "Forwarder代码总结",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "forwarder-sidebar": [
        {
          "type": "webview",
          "id": "forwarder-view",
          "name": "土豆爆炸",
          "icon": "media/Rust.ico"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "when": "editorTextFocus",
          "command": "forwarder.analyze0",
          "group": "navigation"
        },
        {
          "when": "editorTextFocus",
          "command": "forwarder.analyze",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "forwarder.getFunction",
        "key": "ctrl+alt+f",
        "when": "editorTextFocus"
      },
      {
        "command": "forwarder.analyze",
        "key": "ctrl+alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "workbench.view.extension.forwarder-sidebar",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "focusContextKey"
      }
    ],
    "configuration": {
      "title": "Forwarder",
      "properties": {
        "forwarder.analysis.includePattern": {
          "type": "string",
          "default": "**/*.{ts,js,py,java,cpp,c,cs,go,rs,rb,php}",
          "description": "需要进行结构扫描和图构建的文件类型模式 (Glob syntax)。"
        },
        "forwarder.analysis.excludePattern": {
          "type": "string",
          "default": "**/{node_modules,.git,.svn,out,dist,build,bin,obj,vendor,target,.vscode,.idea}/**",
          "description": "进行结构扫描时需要排斥的文件夹和文件模式 (Glob syntax)。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "esbuild": "^0.27.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}